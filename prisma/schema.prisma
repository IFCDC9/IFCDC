generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String?
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         String
  apiKey       String?   @unique @map("api_key")
  employeeId   String?   @unique @map("employee_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  employee               Employee?                @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  acknowledgements       PolicyAcknowledgement[]
  formSubmissions        FormSubmission[]
  assignedSubmissions    FormSubmission[]         @relation("SupervisorAssigned")
  encounters             Encounter[]

  @@map("users")
}

model Chapter {
  id        Int      @id @default(autoincrement())
  number    Int
  title     String
  section   String
  slug      String   @unique
  body      String
  version   Int      @default(1)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  acknowledgements PolicyAcknowledgement[]

  @@map("chapters")
}

model PolicyAcknowledgement {
  id             Int      @id @default(autoincrement())
  userId         String   @map("user_id") @db.Uuid
  chapterId      Int      @map("chapter_id")
  version        Int
  acknowledgedAt DateTime @default(now()) @map("acknowledged_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId, version])
  @@map("policy_acknowledgements")
}

model Form {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  schema    Json
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  submissions FormSubmission[]

  @@map("forms")
}

model FormSubmission {
  id            Int      @id @default(autoincrement())
  formId        Int      @map("form_id")
  submittedById String?  @map("submitted_by_id") @db.Uuid
  data          Json

  status        String   @default("open")
  riskLevel     String   @default("low") @map("risk_level")
  flagged       Boolean  @default(false)

  assignedToId  String?  @map("assigned_to_id") @db.Uuid

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  form        Form  @relation(fields: [formId], references: [id], onDelete: Cascade)
  submittedBy User? @relation(fields: [submittedById], references: [id], onDelete: SetNull)
  assignedTo  User? @relation("SupervisorAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@map("form_submissions")
}

model BarbershopBooking {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  datetime  DateTime
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("barbershop_bookings")
}

model Client {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  appointments Appointment[]

  @@map("clients")
}

model Appointment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  barberId    String   @map("barber_id") @db.Uuid
  clientId    String   @map("client_id") @db.Uuid
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  serviceName String   @map("service_name")
  status      String   @default("scheduled")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  barber Employee @relation(fields: [barberId], references: [id], onDelete: Cascade)
  client Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("appointments")
}

model Employee {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  email     String   @unique
  phone     String?
  role      String
  location  String?
  startDate DateTime? @map("start_date") @db.Date
  status    String   @default("onboarding")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payRate     Float?   @map("pay_rate")
  payCurrency String?  @map("pay_currency")
  payType     String?  @map("pay_type")

  user         User?
  timeEntries  TimeEntry[]
  appointments Appointment[]
  radioShows   RadioShow[]

  @@map("employees")
}

model RadioShow {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  hostId      String   @map("host_id") @db.Uuid
  dayOfWeek   Int      @map("day_of_week")
  startTime   String   @map("start_time")
  endTime     String   @map("end_time")
  isLive      Boolean  @default(true) @map("is_live")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  host Employee @relation(fields: [hostId], references: [id], onDelete: Cascade)

  @@map("radio_shows")
}

model FundingSource {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  code      String?  @unique
  type      String?
  agency    String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  programs    Program[]
  timeEntries TimeEntry[]

  @@map("funding_sources")
}

model Program {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  code            String?  @unique
  description     String?
  location        String?
  status          String   @default("active")
  fundingSourceId String?  @map("funding_source_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  fundingSource FundingSource? @relation(fields: [fundingSourceId], references: [id], onDelete: SetNull)
  sessions      ProgramSession[]
  enrollments   ProgramEnrollment[]

  @@map("programs")
}

model Participant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  dob       DateTime? @db.Date
  email     String?  @unique
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  enrollments ProgramEnrollment[]

  @@map("participants")
}

model ProgramEnrollment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  programId     String   @map("program_id") @db.Uuid
  participantId String   @map("participant_id") @db.Uuid
  startDate     DateTime? @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  status        String   @default("active")

  program     Program     @relation(fields: [programId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("program_enrollments")
}

model ProgramSession {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  programId   String   @map("program_id") @db.Uuid
  title       String
  date        DateTime
  durationMin Int?     @map("duration_min")
  notes       String?

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("program_sessions")
}

model TimeEntry {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId      String   @map("employee_id") @db.Uuid
  fundingSourceId String?  @map("funding_source_id") @db.Uuid
  date            DateTime @db.Date
  hours           Float
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  employee      Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fundingSource FundingSource? @relation(fields: [fundingSourceId], references: [id], onDelete: SetNull)

  @@map("time_entries")
}

model Patient {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName    String   @map("full_name")
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  contactInfo Json?    @map("contact_info")
  programs    String[] @default([])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  encounters Encounter[]

  @@map("patients")
}

model Encounter {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId     String   @map("patient_id") @db.Uuid
  program       String
  type          String
  summary       String?
  note          String?
  createdById   String   @map("created_by_id") @db.Uuid
  createdByRole String   @map("created_by_role")
  createdAt     DateTime @default(now()) @map("created_at")

  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@map("encounters")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timestamp  DateTime @default(now())
  userId     String?  @map("user_id") @db.Uuid
  userRole   String?  @map("user_role")
  method     String
  path       String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  action     String
  extra      Json?

  @@map("audit_logs")
}

model StaffingPlan {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleKey     String   @unique @map("role_key")
  roleName    String   @map("role_name")
  targetCount Int      @default(0) @map("target_count")
  priority    Int      @default(1)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("staffing_plan")
}
