generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         String
  employeeId   String?   @unique @map("employee_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  employee               Employee?                @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  acknowledgements       PolicyAcknowledgement[]
  formSubmissions        FormSubmission[]
  assignedSubmissions    FormSubmission[]         @relation("SupervisorAssigned")

  @@map("users")
}

model Chapter {
  id        Int      @id @default(autoincrement())
  number    Int
  title     String
  section   String
  slug      String   @unique
  body      String
  version   Int      @default(1)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  acknowledgements PolicyAcknowledgement[]

  @@map("chapters")
}

model PolicyAcknowledgement {
  id             Int      @id @default(autoincrement())
  userId         String   @map("user_id") @db.Uuid
  chapterId      Int      @map("chapter_id")
  version        Int
  acknowledgedAt DateTime @default(now()) @map("acknowledged_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId, version])
  @@map("policy_acknowledgements")
}

model Form {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  schema    Json
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  submissions FormSubmission[]

  @@map("forms")
}

model FormSubmission {
  id            Int      @id @default(autoincrement())
  formId        Int      @map("form_id")
  submittedById String?  @map("submitted_by_id") @db.Uuid
  data          Json

  status        String   @default("open")
  riskLevel     String   @default("low") @map("risk_level")
  flagged       Boolean  @default(false)

  assignedToId  String?  @map("assigned_to_id") @db.Uuid

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  form        Form  @relation(fields: [formId], references: [id], onDelete: Cascade)
  submittedBy User? @relation(fields: [submittedById], references: [id], onDelete: SetNull)
  assignedTo  User? @relation("SupervisorAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@map("form_submissions")
}

model BarbershopBooking {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  datetime  DateTime
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("barbershop_bookings")
}

model Employee {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  email     String   @unique
  phone     String?
  role      String
  location  String?
  startDate DateTime? @map("start_date") @db.Date
  status    String   @default("onboarding")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User?

  @@map("employees")
}

model Program {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  code        String?  @unique
  description String?
  location    String?
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sessions    ProgramSession[]
  enrollments ProgramEnrollment[]

  @@map("programs")
}

model Participant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  dob       DateTime? @db.Date
  email     String?  @unique
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  enrollments ProgramEnrollment[]

  @@map("participants")
}

model ProgramEnrollment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  programId     String   @map("program_id") @db.Uuid
  participantId String   @map("participant_id") @db.Uuid
  startDate     DateTime? @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  status        String   @default("active")

  program     Program     @relation(fields: [programId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("program_enrollments")
}

model ProgramSession {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  programId   String   @map("program_id") @db.Uuid
  title       String
  date        DateTime
  durationMin Int?     @map("duration_min")
  notes       String?

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("program_sessions")
}
