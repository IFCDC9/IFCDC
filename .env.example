# =============================================================================
# IFCDC Headquarters — Environment Configuration Template
# =============================================================================
#
# Copy this file to `.env` and replace every placeholder with your own values:
#
#   cp .env.example .env
#
# Never commit `.env` to version control. This file contains placeholders only.
#
# Legend:
#   [REQUIRED]     — Must be set for production deployments
#   [RECOMMENDED]  — Strongly recommended for local development
#   [OPTIONAL]     — Enables specific integrations or features when set
#
# =============================================================================


# -----------------------------------------------------------------------------
# Core Application
# -----------------------------------------------------------------------------

# [REQUIRED in production] Runtime mode: development | production
NODE_ENV=development

# [RECOMMENDED] HTTP port for the Express + Vite dev server (default: 5000)
PORT=5000

# [REQUIRED in production] Public URL where users access HQ (used for links, OAuth callbacks)
PUBLIC_APP_URL=http://localhost:5000

# [RECOMMENDED] Base URL for external callbacks and integrations (may match PUBLIC_APP_URL)
PUBLIC_BASE_URL=http://localhost:5000

# [OPTIONAL] Legacy alias used by some donation routes
BASE_URL=http://localhost:5000


# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------

# [REQUIRED in production] Secret used to sign JWT session tokens (use a long random string)
JWT_SECRET=your-jwt-secret-replace-with-long-random-string

# [OPTIONAL] Alternative session secret (fallback if JWT_SECRET is unset)
SESSION_SECRET=your-session-secret-replace-with-long-random-string

# [OPTIONAL] JWT expiration duration (default: 7d)
JWT_EXPIRES_IN=7d

# [REQUIRED in production] Super Admin login for IFCDC Headquarters (not grant workflows)
MASTER_OWNER_EMAIL=service@ifcdc.org

# [REQUIRED in production] Super Admin password (use script/generate-super-admin-password.mjs)
FOUNDER_SEED_PASSWORD=your-secure-founder-password

# [OPTIONAL] Display name for the Super Admin account
FOUNDER_NAME=IFCDC Super Admin

# [REQUIRED in production] Grants.gov / SAM.gov operator (grant workflows only — not HQ admin)
GRANTS_OPERATOR_EMAIL=813786b@gmail.com

# [REQUIRED in production] Password for the grants operator account
GRANTS_OPERATOR_PASSWORD=your-secure-grants-operator-password

# [OPTIONAL] Display name for the grants operator account
GRANTS_OPERATOR_NAME=IFCDC Grants Operator

# [OPTIONAL] Email used for executive document delivery (defaults to GRANTS_OPERATOR_EMAIL for grant docs)
FOUNDER_EMAIL=founder@example.com

# [OPTIONAL] Secret required for protected cron endpoints (appointment reminders, etc.)
CRON_SECRET_TOKEN=your-cron-secret-token

# [OPTIONAL] Secret for admin-only API utilities (e.g. exec key generation)
ADMIN_SECRET=your-admin-secret


# -----------------------------------------------------------------------------
# Organization Profile
# -----------------------------------------------------------------------------

# [OPTIONAL] Employer Identification Number (used in reports)
IFCDC_EIN=XX-XXXXXXX

# [OPTIONAL] Principal office address (used in enterprise reporting)
IFCDC_ADDRESS=City, State


# -----------------------------------------------------------------------------
# AURA AI (OpenAI)
# -----------------------------------------------------------------------------

# [RECOMMENDED] OpenAI API key for AURA AI features (Grant Writer, Command Center, chatbot, Voice)
# All AURA surfaces read this key first via server/lib/openaiConfig.ts
OPENAI_API_KEY=sk-your-openai-api-key

# [OPTIONAL] Legacy Replit AI Integrations key — used only if OPENAI_API_KEY is unset or invalid
AI_INTEGRATIONS_OPENAI_API_KEY=

# [OPTIONAL] Legacy Replit proxy base URL — REMOVE on Render production if using OPENAI_API_KEY directly.
# A stale Replit URL here causes 401 Incorrect API Key when paired with a production OpenAI key.
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# [OPTIONAL] Default AURA model (default: gpt-4o-mini)
AURA_MODEL=gpt-4o-mini


# -----------------------------------------------------------------------------
# Email & SMS Notifications
# -----------------------------------------------------------------------------

# [OPTIONAL] Resend API key for transactional email
RESEND_API_KEY=re_your-resend-api-key

# [OPTIONAL] From address for Resend emails
RESEND_FROM_EMAIL=hq@your-domain.example

# [OPTIONAL] Twilio Account SID (must start with AC)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] Twilio Auth Token
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# [OPTIONAL] IFCDC HQ primary line (AURA voice + SMS)
TWILIO_PHONE_NUMBER=+13313168167

# [OPTIONAL] Twilio SMS sender number (defaults to TWILIO_PHONE_NUMBER)
TWILIO_SMS_FROM=+13313168167

# [OPTIONAL] Twilio voice caller ID (defaults to TWILIO_PHONE_NUMBER)
TWILIO_VOICE_FROM=+13313168167

# [OPTIONAL] Twilio from number alias (used by notifications library)
TWILIO_FROM_NUMBER=+13313168167

# [OPTIONAL] Twilio Messaging Service SID (A2P/10DLC — use if configured)
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] Public IFCDC phone number displayed to clients
PUBLIC_IFCDC_PHONE=+13313168167

# [OPTIONAL] Hours before appointments to send SMS reminders (default varies by config)
APPT_REMINDER_LEAD_HOURS=24

# [OPTIONAL] External notifications microservice URL (leave unset to use inline notifications)
IFCDC_NOTIFICATIONS_URL=http://localhost:4102

# [OPTIONAL] Set to true to force inline notification handling instead of external service
IFCDC_NOTIFICATIONS_INLINE=true


# -----------------------------------------------------------------------------
# Payments
# -----------------------------------------------------------------------------

# [OPTIONAL] Stripe secret key for donations and payments
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# [OPTIONAL] Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# [OPTIONAL] PayPal client ID
PAYPAL_CLIENT_ID=your-paypal-client-id

# [OPTIONAL] PayPal client secret
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# [OPTIONAL] PayPal environment: sandbox | live | LIVE | production
PAYPAL_ENV=live


# -----------------------------------------------------------------------------
# Grant Feeds & Government Data
# -----------------------------------------------------------------------------

# [NOT REQUIRED] search2 / fetchOpportunity are public Applicant APIs — no key needed.
# See https://grants.gov/api/api-guide
# Only set if you add authenticated S2S endpoints later:
# GRANTS_GOV_API_KEY=your-grants-gov-api-key
GRANTS_GOV_SEARCH_KEYWORD=community development nonprofit

# [OPTIONAL] SAM.gov API key for federal entity lookup
SAM_GOV_API_KEY=your-sam-gov-api-key

# [OPTIONAL] SAM.gov Unique Entity Identifier for IFCDC
SAM_GOV_UEI=YOUR-SAM-UEI-HERE

# [OPTIONAL] Alias for SAM UEI
IFCDC_SAM_UEI=YOUR-SAM-UEI-HERE


# -----------------------------------------------------------------------------
# Google OAuth (Optional Login Provider)
# -----------------------------------------------------------------------------

# [OPTIONAL] Google OAuth client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# [OPTIONAL] Google OAuth client secret
GOOGLE_CLIENT_SECRET=your-google-client-secret


# -----------------------------------------------------------------------------
# QuickBooks Integration
# -----------------------------------------------------------------------------

# [OPTIONAL] QuickBooks OAuth app client ID
QUICKBOOKS_CLIENT_ID=your-quickbooks-client-id

# [OPTIONAL] QuickBooks OAuth app client secret
QUICKBOOKS_CLIENT_SECRET=your-quickbooks-client-secret

# [OPTIONAL] QuickBooks OAuth redirect URI
QUICKBOOKS_REDIRECT_URI=http://localhost:5000/api/hq/integrations/quickbooks/callback

# [OPTIONAL] QuickBooks API environment: sandbox | production
QUICKBOOKS_ENVIRONMENT=sandbox


# -----------------------------------------------------------------------------
# Software Division — External App URLs
# -----------------------------------------------------------------------------
# Configure launch and health URLs for apps monitored by HQ Software Division.
# Radio and Imperial Foundation use in-app routes by default.

# [OPTIONAL] Barbers App health URL
HQ_BARBERS_HEALTH_URL=http://localhost:3000/

# [OPTIONAL] Music App
HQ_MUSIC_HEALTH_URL=http://localhost:5001/api/health
HQ_MUSIC_LAUNCH_URL=http://localhost:5001

# [OPTIONAL] Radio App
HQ_RADIO_HEALTH_URL=http://localhost:5000/api/health

# [OPTIONAL] Tapis App
HQ_TAPIS_HEALTH_URL=http://localhost:5002/api/health
HQ_TAPIS_LAUNCH_URL=http://localhost:5002

# [OPTIONAL] Inclusive Community App
HQ_INCLUSIVE_HEALTH_URL=http://localhost:5003/api/health
HQ_INCLUSIVE_LAUNCH_URL=http://localhost:5003

# [OPTIONAL] Headquarters self health check
HQ_SELF_HEALTH_URL=http://localhost:5000/api/health

# [OPTIONAL] Swift-Ware App
HQ_SWIFTWARE_HEALTH_URL=http://localhost:5004/api/health
HQ_SWIFTWARE_LAUNCH_URL=http://localhost:5004

# [OPTIONAL] CryptoCoin App
HQ_CRYPTO_HEALTH_URL=http://localhost:5005/api/health
HQ_CRYPTO_LAUNCH_URL=http://localhost:5005


# -----------------------------------------------------------------------------
# IFCDC Microservices (Optional — for split deployments)
# -----------------------------------------------------------------------------
# When running @ifcdc/* packages as separate services, point HQ to them here.
# Defaults use localhost ports 4100–4104.

IFCDC_AUTH_URL=http://localhost:4100
IFCDC_AURA_URL=http://localhost:4101
IFCDC_PAYMENTS_URL=http://localhost:4103
IFCDC_DATABASE_URL=http://localhost:4104


# -----------------------------------------------------------------------------
# Connected App SDK (for Software Division developers)
# -----------------------------------------------------------------------------
# Used when building external apps that connect to HQ via @ifcdc/headquarters-sdk.

IFCDC_HQ_BASE_URL=http://localhost:5000
IFCDC_APP_ID=your-app-id
IFCDC_HQ_TOKEN=your-api-key-from-developer-portal


# -----------------------------------------------------------------------------
# Database (Optional — PostgreSQL / Prisma path)
# -----------------------------------------------------------------------------
# HQ primarily uses SQLite (data/ifcdc.db) at runtime. DATABASE_URL is used by
# Prisma, Replit OIDC sessions, and optional PostgreSQL deployments.

# [OPTIONAL] PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/ifcdc


# -----------------------------------------------------------------------------
# Replit Deployment (Optional)
# -----------------------------------------------------------------------------
# Only needed when running on Replit with OIDC authentication.

REPL_ID=your-replit-repl-id
ISSUER_URL=https://replit.com/oidc
SESSION_SECRET=your-replit-session-secret


# -----------------------------------------------------------------------------
# GitHub (Optional — local push + Integrations Hub health on Render)
# -----------------------------------------------------------------------------
# Local: when `git push origin main` fails (no macOS keychain / SSH).
# Render: set in ifcdc-hq → Environment so /hq/integrations GitHub card shows Connected.
# Classic PAT: repo scope (read). Fine-grained: Contents read on IFCDC9/IFCDC.
# https://github.com/settings/tokens
# Do NOT commit a real token — keep in .env (local) or Render Environment (production).

# GITHUB_TOKEN=ghp_paste_real_token_here
# GITHUB_OWNER=IFCDC9
# GITHUB_REPO=IFCDC
# GITHUB_BRANCH=main


# -----------------------------------------------------------------------------
# Audit & Verification Scripts (Optional)
# -----------------------------------------------------------------------------
# Used by script/platform-audit.mjs and other readiness checks.

IFCDC_BASE_URL=http://127.0.0.1:5000
REPLIT_BASE_URL=https://your-replit-app.example
RENDER_BASE_URL=https://your-render-app.onrender.com
